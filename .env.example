# Production / Railway environment template
# Copy this to .env only for local development.
# For Railway, set these as service environment variables instead of committing secrets.

PORT=8080
APP_ORIGIN=https://your-domain.com
JWT_SECRET=replace-with-a-long-random-secret

MYSQLHOST=your-mysql-host
MYSQLUSER=your-mysql-user
MYSQLPASSWORD=your-mysql-password
MYSQLDATABASE=your-mysql-database
MYSQLPORT=3306

# Optional backup helpers
# BACKUP_DIR is used only by the optional npm backup/restore scripts.
# Do NOT commit real production backup paths or backup files.
BACKUP_DIR=./backups
# Optional: set if mysqldump/mysql are not available in PATH.
# Example Windows: C:\Program Files\MySQL\MySQL Server 8.0\bin
MYSQL_BIN_DIR=

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@your-domain.com

SUPERADMIN_PASSWORD=replace-with-a-private-strong-password

# Notes
# - SUPERADMIN_PASSWORD is required for production / Railway startup.
# - JWT_SECRET is required for JWT signing/verification.
# - SMTP is optional. If omitted, OTP email flows stay unavailable but core ERP flows still run.
# - Local startup may still use built-in DB defaults if MySQL env vars are omitted and PORT stays 8080.
# - Keep MYSQLPASSWORD only in local .env or hosting environment variables, never in npm scripts.
# - Always test restore on a non-production database before using it on live data.
